{
  "name": "@kikiutils/nuxt",
  "type": "module",
  "version": "10.3.4",
  "description": "Nuxt module.",
  "author": "kiki-kanri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kikiutils/nuxt.git"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": [
    "./dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "bumplog": "changelogen --bump --hideAuthorEmail",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0 && stylelint './**/*.{css,scss,vue}' -i ./.gitignore --mw 0",
    "lint:fix": "eslint --fix --max-warnings 0 && stylelint './**/*.{css,scss,vue}' -i ./.gitignore --fix --mw 0",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && changelogen --hideAuthorEmail --push --release && npm publish",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "typecheck": "pnpm run dev:prepare && nuxt typecheck && cd ./playground && nuxt typecheck"
  },
  "peerDependencies": {
    "@element-plus/nuxt": "^1.1.5",
    "@kikiutils/shared": "^15.0.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/robots": "^6.0.7",
    "@unocss/nuxt": "^66.6.8",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1",
    "type-fest": "^5.6.0",
    "unplugin-fonts": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@element-plus/nuxt": {
      "optional": true
    },
    "@kikiutils/shared": {
      "optional": true
    },
    "@nuxtjs/color-mode": {
      "optional": true
    },
    "@nuxtjs/robots": {
      "optional": true
    },
    "@unocss/nuxt": {
      "optional": true
    },
    "@vueuse/nuxt": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "nuxt-security": {
      "optional": true
    },
    "type-fest": {
      "optional": true
    },
    "unplugin-fonts": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "defu": "^6.1.7",
    "mlly": "^1.8.2",
    "sass": "^1.99.0",
    "vue-tsc": "^3.2.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@element-plus/nuxt": "^1.1.5",
    "@eslint/css": "^1.1.0",
    "@html-eslint/parser": "^0.59.0",
    "@kikiutils/eslint-config": "^9.0.1",
    "@kikiutils/eslint-plugin-vue": "^10.2.2",
    "@kikiutils/shared": "^15.0.2",
    "@kikiutils/stylelint-config": "^0.4.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/robots": "^6.0.7",
    "@types/node": "^25.6.0",
    "@unocss/nuxt": "^66.6.8",
    "@vitest/coverage-v8": "^4.1.4",
    "@vueuse/nuxt": "^14.2.1",
    "changelogen": "^0.6.2",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-format": "^2.0.1",
    "knip": "^6.5.0",
    "nitropack": "^2.13.3",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1",
    "tailwind-csstree": "^0.3.1",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "unplugin-fonts": "^2.0.0",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^10.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "unimport": "6.0.2"
    }
  }
}
