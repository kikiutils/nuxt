{
  "name": "package-template",
  "type": "module",
  "version": "0.1.0",
  "description": "",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author-or-organization/repo-name.git"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": null
    },
    "./index": {
      "types": null,
      "import": null,
      "require": null
    },
    "./package.json": "./package.json",
    "./*": "./dist/*.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "./dist",
    "./src"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsdown",
    "bumplog": "changelogen --bump --hideAuthorEmail",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && changelogen --hideAuthorEmail --push --release && npm publish",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "dependencies": {},
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@kikiutils/eslint-config": "^6.0.0",
    "@kikiutils/tsconfigs": "^5.1.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "changelogen": "^0.6.2",
    "knip": "^5.86.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "unplugin-unused": "^0.5.7",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
