{
  "name": "@kikiutils/nuxt",
  "type": "module",
  "version": "11.0.1",
  "description": "Nuxt module.",
  "author": "kiki-kanri",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kikiutils/nuxt.git"
  },
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "./dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "./playground"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "bumplog": "changelogen --bump --hideAuthorEmail",
    "dev": "pnpm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxt prepare playground",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0 && stylelint './**/*.{css,scss,vue}' -i ./.gitignore --mw 0",
    "lint:fix": "eslint --fix --max-warnings 0 && stylelint './**/*.{css,scss,vue}' -i ./.gitignore --fix --mw 0",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && changelogen --hideAuthorEmail --push --release && npm publish",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "test:types": "vue-tsc --noEmit && cd ./playground && vue-tsc --noEmit",
    "typecheck": "vue-tsc --noEmit && cd ./playground && vue-tsc --noEmit"
  },
  "peerDependencies": {
    "@element-plus/nuxt": "^1.1.5",
    "@kikiutils/shared": "^15.1.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/robots": "^6.0.9",
    "@unocss/nuxt": "^66.7.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.7",
    "nuxt-security": "^2.6.0",
    "type-fest": "^5.7.0",
    "unplugin-fonts": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@element-plus/nuxt": {
      "optional": true
    },
    "@kikiutils/shared": {
      "optional": true
    },
    "@nuxtjs/color-mode": {
      "optional": true
    },
    "@nuxtjs/robots": {
      "optional": true
    },
    "@unocss/nuxt": {
      "optional": true
    },
    "@vueuse/nuxt": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    },
    "nuxt-security": {
      "optional": true
    },
    "type-fest": {
      "optional": true
    },
    "unplugin-fonts": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.7",
    "defu": "^6.1.7",
    "mlly": "^1.8.2",
    "sass": "^1.100.0",
    "vue-tsc": "^3.3.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@element-plus/nuxt": "^1.1.5",
    "@eslint/css": "^1.3.0",
    "@html-eslint/parser": "^0.61.0",
    "@kikiutils/eslint-config": "^9.1.3",
    "@kikiutils/eslint-plugin-vue": "^10.9.1",
    "@kikiutils/shared": "^15.1.1",
    "@kikiutils/stylelint-config": "^0.4.1",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.7",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/robots": "^6.0.9",
    "@types/node": "^25.9.1",
    "@unocss/nuxt": "^66.7.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vueuse/nuxt": "^14.3.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.4.1",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-format": "^2.0.1",
    "knip": "^6.15.0",
    "nuxt": "^4.4.7",
    "nuxt-security": "^2.6.0",
    "tailwind-csstree": "^0.3.2",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "unplugin-fonts": "^2.0.0",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1"
  }
}
